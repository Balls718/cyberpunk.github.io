<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Cyberpunk Vibes</title>
<style>
  body {
    margin: 0;
    font-family: 'Courier New', monospace;
    background: radial-gradient(circle at top, #0f0f1a, #000);
    color: #00ffe7;
    overflow-x: hidden;
  }

  /* Neon Glow Text */
  .glow {
    text-align: center;
    font-size: 3rem;
    margin-top: 20vh;
    color: #ff00ff;
    text-shadow:
      0 0 5px #ff00ff,
      0 0 10px #ff00ff,
      0 0 20px #ff00ff,
      0 0 40px #00ffe7;
  }

  /* Button */
  .btn {
    display: block;
    margin: 40px auto;
    padding: 15px 30px;
    font-size: 1.2rem;
    color: #00ffe7;
    background: transparent;
    border: 2px solid #00ffe7;
    cursor: pointer;
    transition: 0.3s;
  }

  .btn:hover {
    background: #00ffe7;
    color: black;
    box-shadow: 0 0 20px #00ffe7;
  }

  /* Glitch effect */
  .glitch {
    position: relative;
    color: white;
    font-size: 2rem;
    text-align: center;
  }

  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    left: 0;
    width: 100%;
  }

  .glitch::before {
    animation: glitchTop 1s infinite;
    color: #ff00ff;
    clip-path: inset(0 0 50% 0);
  }

  .glitch::after {
    animation: glitchBottom 1.5s infinite;
    color: #00ffe7;
    clip-path: inset(50% 0 0 0);
  }

  @keyframes glitchTop {
    0% { transform: translate(0); }
    20% { transform: translate(-2px, -2px); }
    40% { transform: translate(2px, 2px); }
    60% { transform: translate(-2px, 2px); }
    80% { transform: translate(2px, -2px); }
    100% { transform: translate(0); }
  }

  @keyframes glitchBottom {
    0% { transform: translate(0); }
    20% { transform: translate(2px, 2px); }
    40% { transform: translate(-2px, -2px); }
    60% { transform: translate(2px, -2px); }
    80% { transform: translate(-2px, 2px); }
    100% { transform: translate(0); }
  }

  /* Grid lines background */
  .grid {
    position: fixed;
    width: 100%;
    height: 100%;
    background-image:
      linear-gradient(#00ffe7 1px, transparent 1px),
      linear-gradient(90deg, #00ffe7 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.05;
    z-index: -1;
  }
</style>
</head>

<body>

<div class="grid"></div>

<h1 class="glow">NEON CITY</h1>

<div class="glitch" data-text="WELCOME TO THE FUTURE">
  WELCOME TO THE FUTURE
</div>

<button class="btn" onclick="hack()">ENTER SYSTEM</button>

<script>
function hack() {
  alert("ACCESS GRANTED ⚡");
}
</script>

</body>
</html>
